{
  "name": "windieos",
  "private": false,
  "version": "0.6.23",
  "description": "WindieOS desktop client for the AI Operating System layer.",
  "homepage": "https://api.windieos.com",
  "author": {
    "name": "WindieOS",
    "email": "support@windieos.com"
  },
  "type": "module",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "npm run build:sidecar-runtime && npm run build && electron-builder --config electron-builder.bundled-python.yml",
    "package:win": "npm run build:sidecar-runtime && npm run build && electron-builder --config electron-builder.bundled-python.yml --win nsis",
    "package:mac": "npm run build:sidecar-runtime && npm run build && electron-builder --config electron-builder.bundled-python.yml --mac dmg zip",
    "package:linux": "npm run build:sidecar-runtime && npm run build && electron-builder --config electron-builder.bundled-python.yml --linux AppImage deb rpm",
    "package:win:bundled-python": "npm run package:win",
    "package:mac:bundled-python": "npm run package:mac",
    "package:linux:bundled-python": "npm run package:linux",
    "build:sidecar-runtime": "bash ../scripts/build-sidecar-runtime",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "lint": "eslint . --ext js,jsx,cjs,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:audit": "npm run lint:audit:react && npm run lint:audit:deprecation",
    "lint:audit:react": "eslint . --ext js,jsx,cjs,ts,tsx --plugin react-compiler --rule 'react-compiler/react-compiler:error' --report-unused-disable-directives --max-warnings 0",
    "lint:audit:deprecation": "eslint \"src/**/*.{ts,tsx}\" --plugin deprecation --rule 'deprecation/deprecation:warn' --report-unused-disable-directives",
    "audit:jscpd": "jscpd --gitignore --reporters console,markdown --output ../.audit/plan1/jscpd-report --ignore \"**/__pycache__/**\" --ignore \"**/*.pyc\" ./src ../tests/frontend ../tests/sidecar",
    "audit:knip": "knip --directory . --include files,dependencies,unlisted,binaries,exports,types --no-progress",
    "preview": "vite preview",
    "electron": "node ./scripts/electron-launcher.cjs",
    "electron:dev": "node ./scripts/electron-launcher.cjs --dev",
    "electron:no-summarizer": "node ./scripts/electron-launcher.cjs --no-summarizer",
    "mock-memory-data": "bash -lc 'if command -v python >/dev/null 2>&1; then python src/main/python/dev_seed_mock_memory.py; else python3 src/main/python/dev_seed_mock_memory.py; fi'",
    "electron:mock-memory-data": "npm run mock-memory-data && npm run electron",
    "test:ghost-cursor": "node ./scripts/electron-launcher.cjs --debug-ghost-overlay",
    "test": "NODE_OPTIONS=--no-deprecation jest --config jest.config.cjs",
    "test:ci": "NODE_OPTIONS=--no-deprecation jest --config jest.config.cjs --runInBand",
    "test:shell": "node src/main/test_shell.cjs"
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "katex": "^0.16.35",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "marked-katex-extension": "^5.1.7",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^8.3.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.45.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jscpd": "^4.0.8",
    "json-schema-to-typescript": "^15.0.4",
    "knip": "^5.85.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  }
}
